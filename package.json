{
  "name": "recipes-admin",
  "version": "1.0.0",
  "description": "App based on NodeJS (ExpressJS) and PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrations/runMigrations.ts",
    "migrate:create": "tsx src/db/migrations/createMigration.ts",
    "lint": "echo '=> linting ts' && eslint src --ext .ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node --import tsx --test src/tests/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wyrobowa/recipes-admin.git"
  },
  "author": "Ania Wyroba",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Wyrobowa/recipes-admin/issues"
  },
  "homepage": "https://github.com/Wyrobowa/recipes-admin#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
